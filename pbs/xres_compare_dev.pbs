#!/bin/bash
#PBS -N xres_compare
#PBS -A UCSC0009
#PBS -q develop
#PBS -l select=1:ncpus=4:mem=60GB
#PBS -l walltime=02:00:00
#PBS -j oe
#PBS -o /glade/derecho/scratch/exu/S2S_ExtremeWeather/logs/xres_compare.log

export PYTHONUNBUFFERED=1

set -eo pipefail

module load conda
conda activate my-env

cd /glade/derecho/scratch/exu/S2S_ExtremeWeather

echo "Host: $(hostname)"; echo "Start: $(date)"

python run_xres.py --stage compare

echo "End: $(date)"
ls -la xres_combined_*.png runs/xres/figures/ 2>/dev/null || true
